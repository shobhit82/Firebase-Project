<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=|, initial-scale=1.0">
    <title>Document</title>
</head> 
    <style>
        form .div{
            padding: 5px;
            display: flex;
            align-items: start;
            justify-content: space-between;
        }
        form .div label{
            font-weight: 800;
            margin-right: 5px;
        }
        form .div input{
            border: 1px solid lightgray;
            outline: none;
            margin-left: 4px;
            border-radius: 3px;
            padding: 3px;
        }
        form button{
                background-color: green;
                padding: 7px;
                border-radius: 6px;
                color: white;
                outline: none;
                border: 0;
                cursor: pointer;
                margin-top: 5px;
        }
        form a{
            margin-left: 80%;
            font-style: italic;
        }
    </style>
<body>
    <%- include('partials/header') %>
        <h2 class="mb-4">Add User</h2>
        <form action="/add" method="POST">
            <div class="div">
                <label>Name:</label>
                <input type="text" name="name" class="form-control" required>
            </div>
            <div class="div">
                <label>Email:</label>
                <input type="email" name="email" class="form-control" required>
            </div>
            <div class="div">
                <label>Age:</label>
                <input type="number" name="age" class="form-control" required>
            </div>
            <button type="submit" class="btn btn-success">
                Save User
            </button>
            <a href="/" class="">
                -Back
            </a>
        </form>
        <%- include('partials/footer') %>
</body>

</html>