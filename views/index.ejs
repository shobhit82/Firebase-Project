                /* background-color: beige; */
            }
            table thead {
                background-color: rgb(244, 225, 197);
                text-align: left;
                /* box-shadow: 0px 0px 3px rgb(190, 187, 187); */
            }
            table thead tr th{
                padding: 5px;
            }
          
            table tbody tr td{
                padding: 4px;
            }
            table tbody tr:nth-child(odd){
                background-color: rgb(250, 248, 246);
            }
            table tbody tr a{
                background-color: rgb(194, 250, 194);
                color: black;
                text-decoration: none;
                border-radius: 3px;
                padding: 4px;
                box-sizing: border-box;

            }
            table tbody tr a:hover{
                      background-color: rgb(169, 240, 169);
            }

            table tbody tr button{
                background-color: rgb(250, 20, 20);
                color: rgb(255, 255, 255);
                border-radius: 3px;
                padding: 5px;
                margin-left: 10px;
                border: 0;
                outline: none;
                cursor: pointer;
                font-weight: 700;
            }
            table  tbody tr button:hover{
                background-color: rgb(220, 11, 11);
            }
