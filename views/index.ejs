<body>
    <%- include('partials/header') %>
        <div class="main">
            <h2>Users List</h2>
            <a href="/add" class="">
                Add User
            </a>
        </div>
        <table class="">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Age</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if(users.length> 0) { %>
                    <% users.forEach(user=> { %>
                        <tr>
                            <td>
                                <%= user.name %>
                            </td>
                            <td>
                                <%= user.email %>
                            </td>
                            <td>
                                <%= user.age %>
                            </td>
                            <td class="both" >
                                <a href="/edit/<%= user.id %>" class="">
                                    Edit
                                </a>
                                <form action="/delete/<%= user.id %>?_method=DELETE" method="POST"
                                    style="display:inline-block">
                                    <button type="submit" class="">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="4" class="text-center">
                                        No Users Found
                                    </td>
                                </tr>
                                <% } %>
            </tbody>
        </table>
        <%- include('partials/footer') %>
