        <style>
            .main{
                /* background-color: yellow; */
                width: 100%;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }
           
            .main a{
                text-decoration: none;
                background-color: green;
                padding: 10px;
                border-radius: 6px;
                color: white;
                cursor: pointer;
            }
            .main a:hover{
                background-color: rgb(3, 107, 3);
            }
            .main a:active{
                transform: scale(.98);
            }
            table{
                /* width: 100%; */
